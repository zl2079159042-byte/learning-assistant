# Application
APP_NAME=Learning Assistant
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./learning_assistant.db

# Default LLM provider (qwen | wenxin | deepseek)
DEFAULT_MODEL=deepseek

# Qwen / Tongyi Qianwen
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# Wenxin / Baidu Qianfan
WENXIN_API_KEY=your-wenxin-api-key-here
WENXIN_SECRET_KEY=your-wenxin-secret-key-here
WENXIN_API_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat
WENXIN_MODEL=ernie-speed-128k

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
